# Life Assistant — configuración del backend
# Copia este archivo como backend/.env (local) o configúralo con `fly secrets set` (producción).
# Comprueba tu configuración con: python backend/check_config.py

# ── Obligatorias (el backend NO arranca sin ellas) ────────────────────────────
SECRET_KEY=                 # cadena larga y aleatoria; firma los JWT (openssl rand -hex 32)
DASHBOARD_PASSWORD=         # contraseña de acceso al dashboard (numérica: el input del login es numérico)

# ── Supabase (BD; obligatoria para casi todo) ─────────────────────────────────
SUPABASE_URL=               # https://xxxx.supabase.co
SUPABASE_KEY=               # service_role key (NUNCA la anon key)

# ── Microsoft Graph / Outlook (calendario) ────────────────────────────────────
CLIENT_ID=                  # app registrada en Azure AD (ver docs/DESPLIEGUE.md)
TENANT_ID=
CLIENT_SECRET=
REDIRECT_URI=http://localhost:8000/auth/callback

# ── Servicios externos ────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=        # Distance Matrix (hora de salida con tráfico)
OPENAI_API_KEY=             # Whisper + GPT-4o-mini (ideas por voz)

# ── Tokens de servicio (máquinas; genera valores aleatorios distintos) ───────
HA_POLL_TOKEN=              # Home Assistant sondea /ha/* con este token
HEALTH_INGEST_TOKEN=        # Health Auto Export / iOS Shortcuts envían salud con este token

# ── Personalización de la instancia ───────────────────────────────────────────
TIMEZONE=Europe/Madrid      # zona horaria IANA del usuario
HOME_ADDRESS=               # origen por defecto para "¿a qué hora salir?" (tu dirección)
CLASSES_CALENDAR=clases     # nombre del calendario de clases en Outlook (vacío si no aplica)
CORS_ORIGINS=http://localhost:5173,https://TU-APP.vercel.app
WEATHER_LAT=40.4168         # coordenadas del widget de clima (Open-Meteo, sin API key)
WEATHER_LON=-3.7038         # por defecto Madrid — pon las tuyas

# ── Opcionales ────────────────────────────────────────────────────────────────
# MAX_JOB_ATTEMPTS=3        # reintentos máximos de un job del agente PC
# LOGIN_MAX_ATTEMPTS=5      # rate limiting del login
# LOGIN_WINDOW_SECONDS=300
# HA_URL=                   # no lo usa el backend (HA sondea al backend, no al revés)
# HA_TOKEN=

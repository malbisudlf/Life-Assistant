# Life Assistant — Agente PC
# Copia este archivo como .env y rellena los valores

# JWT del dashboard (el mismo token que usas para hacer login en el dashboard)
# Puedes obtenerlo abriendo las DevTools del navegador → Application → Local Storage → la_token
LA_TOKEN=

# Backend
LA_API_BASE=https://backend-tender-glow-160.fly.dev

# Supabase (mismos valores que en backend/.env)
SUPABASE_URL=
SUPABASE_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# Cuenta Google/Deusto para el selector de cuenta en Alud
ALUD_ACCOUNT=tu.nombre@opendeusto.es

# Ruta al perfil de Edge (dejar en blanco para usar el default de Windows)
EDGE_PROFILE_DIR=
